import pandas as pd
import numpy as np
from xgboost import XGBRegressor
from sklearn.ensemble import AdaBoostRegressor
from sklearn.metrics import mean_absolute_error, root_mean_squared_error, mean_absolute_percentage_error

# 1. Load the data
path = "/Users/rutgersmac/Library/CloudStorage/OneDrive-TilburgUniversity/CSAI/Year 2/Y2 S2/RS Workshop/Code/train.csv"
# WARNING: 100k rows is only a couple of days in this dataset. 
# You will need to increase this to get Weekly/Monthly splits to work!
df = pd.read_csv(path, nrows=90000000) 

# 2. Convert date
df['date'] = pd.to_datetime(df['date'])

# 3. Handle NaNs and Binary conversion
df['onpromotion'] = df['onpromotion'].fillna(False).astype(int)




# --- EVALUATION FUNCTION ---
def evaluate(y_true, y_pred, label):
    mae = mean_absolute_error(y_true, y_pred)
    rmse = root_mean_squared_error(y_true, y_pred) 
    mape = mean_absolute_percentage_error(y_true, y_pred)
    print(f"   --- {label} ---")
    print(f"   MAE: {mae:.2f} | RMSE: {rmse:.2f} | MAPE: {mape:.2%}")





# --- EXPERIMENT PIPELINE ---
def test_granularity(raw_data, freq_code, label):
    print(f"\n========================================")
    print(f" GRANULARITY: {label} ")
    print(f"========================================")
    
    # Aggregate data: Grouping by the frequency and summing sales/promotions
    df_agg = raw_data.set_index('date').resample(freq_code).agg({
        'unit_sales': 'sum',
        'onpromotion': 'sum'
    }).reset_index()
    
    # Drop any empty periods created by resampling
    df_agg = df_agg.dropna()
    
    # Check if we have enough data to actually split and train
    if len(df_agg) < 5:
        print(f"   [ERROR] Only {len(df_agg)} data points found for {label} level.")
        print("   You need to load more rows (increase nrows) to test this horizon!")
        return

    # Re-create Time Index for the aggregated dataframe
    df_agg['time_index'] = (df_agg['date'] - df_agg['date'].min()).dt.days
    
    # Split 80/20
    split_idx = int(len(df_agg) * 0.8)
    train, test = df_agg.iloc[:split_idx], df_agg.iloc[split_idx:]
    
    X_train = train[['time_index', 'onpromotion']]
    y_train = train['unit_sales']
    X_test = test[['time_index', 'onpromotion']]
    y_test = test['unit_sales']
    
    # Initialize & Train
    xgb_model = XGBRegressor(n_estimators=100, objective="reg:squarederror")
    ada_model = AdaBoostRegressor(n_estimators=100)
    
    xgb_model.fit(X_train, y_train)
    ada_model.fit(X_train, y_train)
    
    # Evaluate
    evaluate(y_test, xgb_model.predict(X_test), "XGBoost")
    evaluate(y_test, ada_model.predict(X_test), "AdaBoost")


# --- RUN THE TESTS ---
# First, group the raw data by day, since 100k rows contains many store/item entries per day
df_daily = df.groupby('date').agg({'unit_sales': 'sum', 'onpromotion': 'sum'}).reset_index()

# 'D' = Daily, 'W' = Weekly, 'ME' = Month End
test_granularity(df_daily, 'D', "DAILY")
test_granularity(df_daily, 'W', "WEEKLY")
test_granularity(df_daily, 'ME', "MONTHLY")
