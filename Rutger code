import pandas as pd
import numpy as np
from xgboost import XGBRegressor
from sklearn.ensemble import AdaBoostRegressor
from sklearn.metrics import mean_absolute_error, mean_squared_error, root_mean_squared_error, mean_absolute_percentage_error

# 1. Load a manageable chunk of the actual data
path = "/Users/rutgersmac/Library/CloudStorage/OneDrive-TilburgUniversity/CSAI/Year 2/Y2 S2/RS Workshop/Code/train.csv"
df = pd.read_csv(path, nrows=100000) # Using 100k rows for testing

# 2. Convert date and sort (Crucial for Time-Series)
df['date'] = pd.to_datetime(df['date'])
df = df.sort_values('date')

# 3. Handle NaNs and Binary conversion for 'onpromotion'
# Filling NaNs with False (0) as discussed in your data plan
df['onpromotion'] = df['onpromotion'].fillna(False).astype(int)

# 4. Create Time Index (Converting date to ordinal for the model)
df['time_index'] = (df['date'] - df['date'].min()).dt.days

# 5. Temporal Split (No Shuffling!)
# We take the first 80% of time for training, last 20% for testing
split_idx = int(len(df) * 0.8)
train, test = df.iloc[:split_idx], df.iloc[split_idx:]

X_train = train[['time_index', 'onpromotion']]
y_train = train['unit_sales']
X_test = test[['time_index', 'onpromotion']]
y_test = test['unit_sales']

# 6. Initialize both models
xgb_model = XGBRegressor(n_estimators=100, objective="reg:squarederror")
ada_model = AdaBoostRegressor(n_estimators=100)

# 7. Train and Predict
xgb_model.fit(X_train, y_train)
ada_model.fit(X_train, y_train)

xgb_preds = xgb_model.predict(X_test)
ada_preds = ada_model.predict(X_test)

# 8. Evaluation (Including MAPE as per your Methods section)
def evaluate(y_true, y_pred, label):
    mae = mean_absolute_error(y_true, y_pred)
    # Use the specific RMSE function instead of the squared parameter
    rmse = root_mean_squared_error(y_true, y_pred) 
    mape = mean_absolute_percentage_error(y_true, y_pred)
    print(f"--- {label} Results ---")
    print(f"MAE: {mae:.2f} | RMSE: {rmse:.2f} | MAPE: {mape:.2%}\n")

evaluate(y_test, xgb_preds, "XGBoost")
evaluate(y_test, ada_preds, "AdaBoost")
